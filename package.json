{
  "name": "alpha-loop",
  "version": "0.2.0",
  "description": "Agent-agnostic automated development loop: Plan -> Build -> Test -> Review -> Ship",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "loop": "bash scripts/loop.sh",
    "loop:once": "bash scripts/loop.sh --once",
    "loop:dry": "DRY_RUN=true bash scripts/loop.sh --once",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.6.0",
    "typescript": "^5.2.2"
  }
}
