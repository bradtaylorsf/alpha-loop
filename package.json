{
  "name": "alpha-loop",
  "version": "0.1.0",
  "description": "Agent-agnostic automated development loop: Plan -> Build -> Test -> Review -> Ship",
  "type": "module",
  "bin": {
    "alpha-loop": "./dist/cli/index.js"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "PORT=4000 tsx watch src/server/index.ts",
    "dev:client": "vite --port 4001",
    "build": "tsc && vite build",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "loop": "bash scripts/loop.sh",
    "loop:once": "bash scripts/loop.sh --once",
    "loop:dry": "DRY_RUN=true bash scripts/loop.sh --once",
    "test": "jest --runInBand && jest --runInBand --config jest.client.config.cjs",
    "test:server": "jest --runInBand",
    "test:client": "jest --runInBand --config jest.client.config.cjs",
    "test:unit": "jest --runInBand",
    "test:api": "jest --runInBand",
    "test:e2e": "npx playwright test",
    "test:full": "RECORD_FIXTURES=true jest --runInBand && RECORD_FIXTURES=true jest --runInBand --config jest.client.config.cjs",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.6.0",
    "typescript": "^5.2.2",
    "vite": "^8.0.3"
  }
}
