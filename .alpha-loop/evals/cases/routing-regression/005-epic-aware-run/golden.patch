@@ -0,0 +1,34 @@
+import { triageCommand } from '../../src/commands/triage';
+import { roadmapCommand } from '../../src/commands/roadmap';
+import { runCommand } from '../../src/commands/run';
+
+describe('epic-first workflow', () => {
+  test('triage can propose an epic, roadmap can schedule it, and run can process it', async () => {
+    const proposedEpic = {
+      title: 'Epic: checkout workflow',
+      goal: 'Ship checkout end to end',
+      rationale: 'The child issues form one cohesive deliverable',
+      orderedChildIssueNumbers: [101, 102],
+      acceptanceCriteria: ['Checkout works end to end'],
+      selected: true,
+    };
+
+    await triageCommand({ dryRun: true });
+    await roadmapCommand({ dryRun: true });
+    await runCommand({ epic: 200, once: true, dryRun: true });
+
+    expect(proposedEpic.orderedChildIssueNumbers).toEqual([101, 102]);
+  });
+});
